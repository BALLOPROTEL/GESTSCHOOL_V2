{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "corepack enable && corepack prepare pnpm@10.24.0 --activate && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @gestschool/web-admin build",
  "outputDirectory": "apps/web-admin/dist",
  "rewrites": [
    {
      "source": "/api/v1",
      "destination": "https://gestschool-c880.onrender.com/api/v1"
    },
    {
      "source": "/api/v1/(.*)",
      "destination": "https://gestschool-c880.onrender.com/api/v1/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
