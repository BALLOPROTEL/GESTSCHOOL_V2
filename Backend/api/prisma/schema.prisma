model RoomAssignment {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  roomId         String          @map("room_id") @db.Uuid
  schoolYearId   String          @map("school_year_id") @db.Uuid
  classId        String?         @map("class_id") @db.Uuid
  levelId        String?         @map("level_id") @db.Uuid
  cycleId        String?         @map("cycle_id") @db.Uuid
  track          AcademicTrack?  @map("track")
  subjectId      String?         @map("subject_id") @db.Uuid
  periodId       String?         @map("period_id") @db.Uuid
  assignmentType String          @default("SHARED_ROOM") @map("assignment_type") @db.VarChar(40)
  startDate      DateTime?       @map("start_date") @db.Date
  endDate        DateTime?       @map("end_date") @db.Date
  status         String          @default("ACTIVE") @db.VarChar(20)
  comment        String?         @db.VarChar(500)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  room           Room            @relation(fields: [roomId], references: [id], onDelete: Restrict)
  schoolYear     SchoolYear      @relation(fields: [schoolYearId], references: [id], onDelete: Restrict)
  classroom      Classroom?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  level          Level?          @relation(fields: [levelId], references: [id], onDelete: SetNull)
  cycle          Cycle?          @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  subject        Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  academicPeriod AcademicPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@unique([tenantId, roomId, schoolYearId, classId, levelId, cycleId, track, subjectId, periodId, assignmentType], map: "room_assignments_scope_key")
  @@index([tenantId, roomId, status], map: "idx_room_assignments_tenant_room_status")
  @@index([tenantId, schoolYearId, status], map: "idx_room_assignments_tenant_year_status")
  @@index([tenantId, track], map: "idx_room_assignments_tenant_track")
  @@map("room_assignments")
}

