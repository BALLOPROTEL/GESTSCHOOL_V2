generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AcademicTrack {
  FRANCOPHONE
  ARABOPHONE
}

enum RotationGroup {
  GROUP_A
  GROUP_B
}

enum AcademicPlacementStatus {
  ACTIVE
  INACTIVE
  COMPLETED
  SUSPENDED
}

enum AcademicStage {
  PRIMARY
  SECONDARY
  HIGHER

  @@map("academic_stage")
}

enum PedagogicalRuleType {
  FIRST_CYCLE_PARALLEL_ROTATION
  SECOND_CYCLE_WEEKLY_TRACK_SPLIT
}

enum ReportCardMode {
  TRACK_SINGLE
  PRIMARY_COMBINED

  @@map("report_card_mode")
}

model Student {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  matricule   String      @db.VarChar(30)
  firstName   String      @map("first_name") @db.VarChar(100)
  lastName    String      @map("last_name") @db.VarChar(100)
  sex         String      @db.Char(1)
  birthDate   DateTime?   @map("birth_date") @db.Date
  birthPlace  String?     @map("birth_place") @db.VarChar(120)
  nationality String?     @db.VarChar(80)
  address     String?
  phone       String?     @db.VarChar(30)
  email       String?     @db.VarChar(120)
  photoUrl    String?     @map("photo_url")
  establishmentId String? @map("establishment_id") @db.Uuid
  admissionDate DateTime? @map("admission_date") @db.Date
  administrativeNotes String? @map("administrative_notes") @db.VarChar(1000)
  internalId String? @map("internal_id") @db.VarChar(40)
  birthCertificateNo String? @map("birth_certificate_no") @db.VarChar(80)
  specialNeeds String? @map("special_needs") @db.VarChar(1000)
  primaryLanguage String? @map("primary_language") @db.VarChar(60)
  userId      String?     @unique(map: "students_user_id_key") @map("user_id") @db.Uuid
  status      String      @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz(6)
  archivedAt  DateTime?   @map("archived_at") @db.Timestamptz(6)
  enrollments Enrollment[]
  invoices    Invoice[]
  grades      GradeEntry[]
  reportCards ReportCard[]
  attendance  Attendance[]
  notifications Notification[]
  parentLinks ParentStudentLink[]
  trackPlacements StudentTrackPlacement[]
  user        User?       @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tenantId, matricule], map: "students_tenant_id_matricule_key")
  @@map("students")
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  username      String         @db.VarChar(150)
  email         String?        @db.VarChar(150)
  phone         String?        @db.VarChar(30)
  passwordHash  String         @map("password_hash")
  role          String         @db.VarChar(30)
  accountType   String         @default("STAFF") @map("account_type") @db.VarChar(30)
  displayName   String?        @map("display_name") @db.VarChar(180)
  firstName     String?        @map("first_name") @db.VarChar(100)
  lastName      String?        @map("last_name") @db.VarChar(100)
  avatarUrl     String?        @map("avatar_url")
  establishmentId String?      @map("establishment_id") @db.Uuid
  staffFunction String?        @map("staff_function") @db.VarChar(120)
  department    String?        @db.VarChar(120)
  notes         String?        @db.VarChar(1000)
  mustChangePasswordAtFirstLogin Boolean @default(false) @map("must_change_password_at_first_login")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz(6)
  refreshTokens RefreshToken[]
  iamAuditLogs  IamAuditLog[]
  teacherAssignments TeacherClassAssignment[] @relation("TeacherAssignments")
  teacherProfile Teacher? @relation("TeacherUser")
  teacherDocumentUploads TeacherDocument[] @relation("TeacherDocumentUploads")
  parentLinks ParentStudentLink[] @relation("ParentStudentLinks")
  parentProfile Parent? @relation("ParentUser")
  studentProfile Student? @relation("StudentUser")

  @@unique([tenantId, username], map: "users_tenant_id_username_key")
  @@unique([tenantId, email], map: "users_tenant_id_email_key")
  @@index([tenantId, accountType], map: "idx_users_tenant_account_type")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([tokenHash], map: "refresh_tokens_token_hash_key")
  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}

model SchoolYear {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  code        String         @db.VarChar(20)
  label       String         @db.VarChar(40)
  startDate   DateTime       @map("start_date") @db.Date
  endDate     DateTime       @map("end_date") @db.Date
  status      String         @default("DRAFT") @db.VarChar(20)
  previousYearId String?     @map("previous_year_id") @db.Uuid
  isActive    Boolean        @default(false) @map("is_active")
  isDefault   Boolean        @default(false) @map("is_default")
  sortOrder   Int?           @map("sort_order")
  comment     String?        @db.VarChar(500)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  previousYear SchoolYear?   @relation("SchoolYearPreviousYear", fields: [previousYearId], references: [id])
  nextYears   SchoolYear[]   @relation("SchoolYearPreviousYear")
  classes     Classroom[]
  cycles      Cycle[]
  periods     AcademicPeriod[]
  enrollments Enrollment[]
  feePlans    FeePlan[]
  invoices    Invoice[]
  attendance  Attendance[]
  timetableSlots TimetableSlot[]
  teacherAssignments TeacherClassAssignment[]
  teacherPedagogicalAssignments TeacherAssignment[]
  roomAssignments RoomAssignment[]
  roomAvailabilities RoomAvailability[]
  trackPlacements StudentTrackPlacement[]
  pedagogicalRules PedagogicalRule[]

  @@unique([tenantId, code], map: "school_years_tenant_id_code_key")
  @@unique([tenantId, label], map: "school_years_tenant_id_label_key")
  @@map("school_years")
}

model Cycle {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  schoolYearId String @map("school_year_id") @db.Uuid
  code      String   @db.VarChar(20)
  label     String   @db.VarChar(100)
  academicStage AcademicStage @default(PRIMARY) @map("academic_stage")
  sortOrder Int      @map("sort_order")
  description String? @db.VarChar(500)
  theoreticalAgeMin Int? @map("theoretical_age_min")
  theoreticalAgeMax Int? @map("theoretical_age_max")
  status    String   @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id])
  levels    Level[]
  teacherSkills TeacherSkill[]
  roomAssignments RoomAssignment[]
  pedagogicalRules PedagogicalRule[]

  @@unique([tenantId, schoolYearId, code], map: "cycles_tenant_id_school_year_id_code_key")
  @@map("cycles")
}

model Level {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  cycleId   String      @map("cycle_id") @db.Uuid
  track     AcademicTrack @default(FRANCOPHONE)
  code      String      @db.VarChar(20)
  label     String      @db.VarChar(100)
  alias     String?     @db.VarChar(50)
  sortOrder Int         @map("sort_order")
  status    String      @default("ACTIVE") @db.VarChar(20)
  theoreticalAge Int?   @map("theoretical_age")
  description String?   @db.VarChar(500)
  defaultSection String? @map("default_section") @db.VarChar(100)
  rotationGroup RotationGroup? @map("rotation_group")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  cycle     Cycle       @relation(fields: [cycleId], references: [id])
  classes   Classroom[]
  feePlans  FeePlan[]
  subjectScopes SubjectLevelScope[]
  teacherSkills TeacherSkill[]
  roomAssignments RoomAssignment[]
  trackPlacements StudentTrackPlacement[]
  pedagogicalRules PedagogicalRule[]

  @@unique([tenantId, cycleId, code], map: "levels_tenant_id_cycle_id_code_key")
  @@map("levels")
}

model Classroom {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  schoolYearId String      @map("school_year_id") @db.Uuid
  levelId      String      @map("level_id") @db.Uuid
  track        AcademicTrack @default(FRANCOPHONE)
  code         String      @db.VarChar(30)
  label        String      @db.VarChar(100)
  capacity     Int?
  status       String      @default("ACTIVE") @db.VarChar(20)
  homeroomTeacherName String? @map("homeroom_teacher_name") @db.VarChar(140)
  mainRoom     String?     @map("main_room") @db.VarChar(80)
  actualCapacity Int?      @map("actual_capacity")
  filiere      String?     @db.VarChar(100)
  series       String?     @db.VarChar(100)
  speciality   String?     @db.VarChar(120)
  description  String?     @db.VarChar(500)
  teachingMode String?     @map("teaching_mode") @db.VarChar(40)
  rotationGroup RotationGroup? @map("rotation_group")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  schoolYear   SchoolYear  @relation(fields: [schoolYearId], references: [id])
  level        Level       @relation(fields: [levelId], references: [id])
  enrollments  Enrollment[]
  grades       GradeEntry[]
  reportCards  ReportCard[]
  attendance   Attendance[]
  timetableSlots TimetableSlot[]
  teacherAssignments TeacherClassAssignment[]
  teacherPedagogicalAssignments TeacherAssignment[]
  roomAssignments RoomAssignment[]
  trackPlacements StudentTrackPlacement[]
  pedagogicalRules PedagogicalRule[]

  @@unique([tenantId, schoolYearId, code], map: "classes_tenant_id_school_year_id_code_key")
  @@map("classes")
}

model Subject {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  code      String       @db.VarChar(20)
  label     String       @db.VarChar(120)
  status    String       @default("ACTIVE") @db.VarChar(20)
  nature    String       @default("FRANCOPHONE") @db.VarChar(30)
  isArabic  Boolean      @default(false) @map("is_arabic")
  shortLabel String?     @map("short_label") @db.VarChar(60)
  defaultCoefficient Decimal? @map("default_coefficient") @db.Decimal(6, 2)
  category  String?      @db.VarChar(100)
  description String?    @db.VarChar(500)
  color     String?      @db.VarChar(20)
  weeklyHours Decimal?   @map("weekly_hours") @db.Decimal(6, 2)
  isGraded  Boolean      @default(true) @map("is_graded")
  isOptional Boolean     @default(false) @map("is_optional")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  levelScopes SubjectLevelScope[]
  grades    GradeEntry[]
  timetableSlots TimetableSlot[]
  teacherAssignments TeacherClassAssignment[]
  teacherSkills TeacherSkill[]
  teacherPedagogicalAssignments TeacherAssignment[]
  roomAssignments RoomAssignment[]

  @@unique([tenantId, code], map: "subjects_tenant_id_code_key")
  @@map("subjects")
}

model AcademicPeriod {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  schoolYearId String       @map("school_year_id") @db.Uuid
  code         String       @db.VarChar(20)
  label        String       @db.VarChar(100)
  startDate    DateTime     @map("start_date") @db.Date
  endDate      DateTime     @map("end_date") @db.Date
  periodType   String       @map("period_type") @db.VarChar(20)
  sortOrder    Int          @default(1) @map("sort_order")
  status       String       @default("ACTIVE") @db.VarChar(20)
  parentPeriodId String?    @map("parent_period_id") @db.Uuid
  isGradeEntryOpen Boolean  @default(false) @map("is_grade_entry_open")
  gradeEntryDeadline DateTime? @map("grade_entry_deadline") @db.Date
  lockDate     DateTime?    @map("lock_date") @db.Date
  comment      String?      @db.VarChar(500)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  schoolYear   SchoolYear   @relation(fields: [schoolYearId], references: [id])
  parentPeriod AcademicPeriod? @relation("AcademicPeriodHierarchy", fields: [parentPeriodId], references: [id])
  childPeriods AcademicPeriod[] @relation("AcademicPeriodHierarchy")
  grades       GradeEntry[]
  reportCards  ReportCard[]
  teacherPedagogicalAssignments TeacherAssignment[]
  roomAssignments RoomAssignment[]
  roomAvailabilities RoomAvailability[]

  @@unique([tenantId, schoolYearId, code], map: "academic_periods_tenant_id_school_year_id_code_key")
  @@map("academic_periods")
}

model SubjectLevelScope {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  subjectId String   @map("subject_id") @db.Uuid
  levelId   String   @map("level_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  level     Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([tenantId, subjectId, levelId], map: "subject_level_scopes_tenant_id_subject_id_level_id_key")
  @@index([tenantId, levelId], map: "idx_subject_level_scopes_level")
  @@map("subject_level_scopes")
}

model Enrollment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  schoolYearId     String    @map("school_year_id") @db.Uuid
  studentId        String    @map("student_id") @db.Uuid
  classId          String    @map("class_id") @db.Uuid
  track            AcademicTrack @default(FRANCOPHONE)
  enrollmentDate   DateTime  @map("enrollment_date") @db.Date
  enrollmentStatus String    @default("ENROLLED") @map("enrollment_status") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  schoolYear       SchoolYear @relation(fields: [schoolYearId], references: [id])
  student          Student    @relation(fields: [studentId], references: [id])
  classroom        Classroom  @relation(fields: [classId], references: [id])
  placement        StudentTrackPlacement? @relation("LegacyEnrollmentPlacement")

  @@unique([tenantId, schoolYearId, studentId, track], map: "enrollments_tenant_id_school_year_id_student_id_track_key")
  @@map("enrollments")
}

model StudentTrackPlacement {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String                  @map("tenant_id") @db.Uuid
  studentId          String                  @map("student_id") @db.Uuid
  schoolYearId       String                  @map("school_year_id") @db.Uuid
  track              AcademicTrack
  levelId            String                  @map("level_id") @db.Uuid
  classId            String?                 @map("class_id") @db.Uuid
  legacyEnrollmentId String?                 @unique(map: "student_track_placements_legacy_enrollment_id_key") @map("legacy_enrollment_id") @db.Uuid
  placementStatus    AcademicPlacementStatus @default(ACTIVE) @map("placement_status")
  isPrimary          Boolean                 @default(false) @map("is_primary")
  startDate          DateTime?               @map("start_date") @db.Date
  endDate            DateTime?               @map("end_date") @db.Date
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  student            Student                 @relation(fields: [studentId], references: [id])
  schoolYear         SchoolYear              @relation(fields: [schoolYearId], references: [id])
  level              Level                   @relation(fields: [levelId], references: [id])
  classroom          Classroom?              @relation(fields: [classId], references: [id])
  legacyEnrollment   Enrollment?             @relation("LegacyEnrollmentPlacement", fields: [legacyEnrollmentId], references: [id], onDelete: SetNull)
  grades             GradeEntry[]
  reportCards        ReportCard[]
  secondaryReportCards ReportCard[]          @relation("ReportCardSecondaryPlacement")
  attendance         Attendance[]
  billingInvoices    Invoice[]               @relation("InvoiceBillingPlacement")
  secondaryInvoices  Invoice[]               @relation("InvoiceSecondaryPlacement")

  @@unique([tenantId, schoolYearId, studentId, track], map: "uq_student_track_placements_scope")
  @@index([tenantId, studentId, schoolYearId], map: "idx_student_track_placements_student_year")
  @@index([tenantId, classId], map: "idx_student_track_placements_class")
  @@map("student_track_placements")
}

model FeePlan {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  schoolYearId String    @map("school_year_id") @db.Uuid
  levelId      String    @map("level_id") @db.Uuid
  label        String    @db.VarChar(120)
  totalAmount  Decimal   @map("total_amount") @db.Decimal(14, 2)
  currency     String    @default("CFA") @db.Char(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  level        Level      @relation(fields: [levelId], references: [id])
  invoices     Invoice[]

  @@unique([tenantId, schoolYearId, levelId, label], map: "fee_plans_tenant_id_school_year_id_level_id_label_key")
  @@map("fee_plans")
}

model Invoice {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  schoolYearId String    @map("school_year_id") @db.Uuid
  feePlanId    String?   @map("fee_plan_id") @db.Uuid
  billingPlacementId String? @map("billing_placement_id") @db.Uuid
  secondaryPlacementId String? @map("secondary_placement_id") @db.Uuid
  invoiceNo    String    @map("invoice_no") @db.VarChar(40)
  amountDue    Decimal   @map("amount_due") @db.Decimal(14, 2)
  amountPaid   Decimal   @default(0) @map("amount_paid") @db.Decimal(14, 2)
  status       String    @default("OPEN") @db.VarChar(20)
  dueDate      DateTime? @map("due_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  student      Student   @relation(fields: [studentId], references: [id])
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  feePlan      FeePlan?  @relation(fields: [feePlanId], references: [id])
  billingPlacement StudentTrackPlacement? @relation("InvoiceBillingPlacement", fields: [billingPlacementId], references: [id], onDelete: SetNull)
  secondaryPlacement StudentTrackPlacement? @relation("InvoiceSecondaryPlacement", fields: [secondaryPlacementId], references: [id], onDelete: SetNull)
  payments     Payment[]

  @@unique([tenantId, invoiceNo], map: "invoices_tenant_id_invoice_no_key")
  @@index([tenantId, studentId, status], map: "idx_invoices_tenant_student_status")
  @@map("invoices")
}

model Payment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  invoiceId         String    @map("invoice_id") @db.Uuid
  receiptNo         String    @map("receipt_no") @db.VarChar(40)
  paidAmount        Decimal   @map("paid_amount") @db.Decimal(14, 2)
  paymentMethod     String    @map("payment_method") @db.VarChar(30)
  paidAt            DateTime  @map("paid_at") @db.Timestamptz(6)
  referenceExternal String?   @map("reference_external") @db.VarChar(120)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  invoice           Invoice   @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, receiptNo], map: "payments_tenant_id_receipt_no_key")
  @@index([tenantId, paidAt], map: "idx_payments_tenant_paid_at")
  @@map("payments")
}

model GradeEntry {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  studentId        String    @map("student_id") @db.Uuid
  classId          String    @map("class_id") @db.Uuid
  placementId      String?   @map("placement_id") @db.Uuid
  track            AcademicTrack @default(FRANCOPHONE)
  subjectId        String    @map("subject_id") @db.Uuid
  academicPeriodId String    @map("academic_period_id") @db.Uuid
  assessmentLabel  String    @map("assessment_label") @db.VarChar(120)
  assessmentType   String    @default("DEVOIR") @map("assessment_type") @db.VarChar(30)
  score            Decimal   @db.Decimal(5, 2)
  scoreMax         Decimal   @default(20) @map("score_max") @db.Decimal(5, 2)
  absent           Boolean   @default(false)
  comment          String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  student          Student   @relation(fields: [studentId], references: [id])
  classroom        Classroom @relation(fields: [classId], references: [id])
  placement        StudentTrackPlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)
  subject          Subject   @relation(fields: [subjectId], references: [id])
  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])

