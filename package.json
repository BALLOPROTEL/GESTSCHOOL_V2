{
  "name": "gestschool",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev:api": "pnpm --filter @gestschool/api start:dev",
    "dev:worker": "pnpm --filter @gestschool/api start:worker:dev",
    "dev:web": "pnpm --filter @gestschool/web-admin dev",
    "build:api": "pnpm --filter @gestschool/api build",
    "build:web": "pnpm --filter @gestschool/web-admin build",
    "render:build:api": "pnpm --filter @gestschool/api prisma:generate && pnpm --filter @gestschool/api build",
    "render:start:api": "pnpm --filter @gestschool/api start:prod",
    "render:start:worker": "pnpm --filter @gestschool/api start:worker",
    "lint": "pnpm lint:api && pnpm lint:web",
    "build": "pnpm build:api && pnpm build:web",
    "lint:api": "pnpm --filter @gestschool/api lint",
    "lint:web": "pnpm --filter @gestschool/web-admin lint"
  }
}
