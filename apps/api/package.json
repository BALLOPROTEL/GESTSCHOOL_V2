{
  "name": "@gestschool/api",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "node --watch --watch-path src -r ts-node/register/transpile-only -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main",
    "start:worker:dev": "node --watch --watch-path src -r ts-node/register/transpile-only -r tsconfig-paths/register src/worker.ts",
    "start:worker": "node dist/worker",
    "lint": "eslint \"src/**/*.ts\"",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:db": "pnpm run db:migrate:deploy && jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:db:fresh": "pnpm run db:generate && pnpm run db:migrate:deploy && jest --config ./test/jest-e2e.json --runInBand",
    "db:generate": "node ./scripts/prisma-command.cjs generate",
    "db:status": "node ./scripts/prisma-command.cjs migrate status",
    "db:migrate:deploy": "node ./scripts/prisma-command.cjs migrate deploy",
    "db:seed:users": "node ./scripts/run-ts-script-with-env.cjs prisma/seed-users.ts",
    "db:seed:minimal": "node ./scripts/run-ts-script-with-env.cjs prisma/seed-minimal.ts",
    "db:admin": "node ./scripts/run-ts-script-with-env.cjs scripts/postgres-database-admin.ts",
    "db:reset-staff-password": "node ./scripts/run-ts-script-with-env.cjs scripts/reset-staff-password.ts",
    "audit:legacy": "node ./scripts/run-ts-script-with-env.cjs scripts/legacy-inventory.ts",
    "audit:precutover": "node ./scripts/run-ts-script-with-env.cjs scripts/precutover-db-audit.ts",
    "migrate:timetable:dry-run": "node ./scripts/run-ts-script-with-env.cjs scripts/timetable-reference-backfill.ts",
    "migrate:timetable:apply": "node ./scripts/run-ts-script-with-env.cjs scripts/timetable-reference-backfill.ts --apply",
    "seed:users": "pnpm run db:seed:users",
    "prisma:generate": "pnpm run db:generate",
    "prisma:migrate:dev": "node ./scripts/prisma-command.cjs migrate dev",
    "prisma:migrate:deploy": "pnpm run db:migrate:deploy"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "redis": "5.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/testing": "^11.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "jest": "^30.2.0",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1"
  }
}
